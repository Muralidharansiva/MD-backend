DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,md-studio-backend.onrender.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://md-studio.vercel.app
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://md-studio.vercel.app,https://md-studio-backend.onrender.com
DATABASE_URL=
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=None
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=hello@mdstudio.in
RATE_LIMIT_LOGIN=60/hour
RATE_LIMIT_REGISTER=20/hour
RATE_LIMIT_OTP_REQUEST=20/hour
RATE_LIMIT_OTP_VERIFY=30/hour
RATE_LIMIT_BOOKING_WRITE=20/minute
RATE_LIMIT_SLOT_LOCK=60/minute
